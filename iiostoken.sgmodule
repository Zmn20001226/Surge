#!name=iios获取token 
#!desc=积分可以兑换苹果应用账号

[Script]

iios_30 = type=http-request, pattern=^https:\/\/www\.iios\.fun\/api\/(base|user\/info)$, script-path=https://raw.githubusercontent.com/Sliverkiss/GoodNight/master/Script/iios.js, timeout=60, script-update-interval=0

[MITM]

hostname = %APPEND% www.iios.fun
